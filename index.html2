<!DOCTYPE html>
<html>

<head>

<title>Ahteshamul Cloud Portfolio</title>

<style>

body{
font-family: Arial;
margin:0;
background:#f4f6f8;
text-align:center;
}

header{
background:#0078D4;
color:white;
padding:60px;
}

section{
padding:40px;
}

.card{
background:white;
padding:20px;
margin:20px auto;
width:250px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

button{
background:#0078D4;
color:white;
padding:10px 20px;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#005fa3;
}

#contact{
display:none;
margin-top:20px;
}

</style>

<script>

function showContact(){
document.getElementById("contact").style.display="block";
}

</script>

</head>

<body>

<header>

<h1>Ahteshamul Ansari</h1>
<p>Cloud & DevOps Learner</p>

<button onclick="showContact()">Contact Me</button>

<div id="contact">
<p>Email: your@email.com</p>
<p>LinkedIn: linkedin.com/in/yourprofile</p>
</div>

</header>

<section>

<div class="card">
<h3>Azure</h3>
<p>Hosting infrastructure on Azure Virtual Machines</p>
</div>

<div class="card">
<h3>Linux</h3>
<p>Managing servers and deployments</p>
</div>

<div class="card">
<h3>DevOps</h3>
<p>Using Git and automation for deployments</p>
</div>

</section>

</body>

</html>
